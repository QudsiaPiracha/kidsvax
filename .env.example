# .env.example - Copy to .env and fill in values
# NEVER commit .env to git. Only .env.example is committed.

# Supabase (client-side safe - public keys, prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only (NEVER prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Anthropic (server-side only -- Claude Agent SDK)
ANTHROPIC_API_KEY=

# Resend (server-side only -- transactional emails)
RESEND_API_KEY=

# Agent Teams (required for claude-bootstrap team workflow)
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1
